<base:WpfUiWindow
    x:Class="Hercules.UI.Elements.Dialogs.ImportExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Hercules.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:Hercules.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Import / Export Configuration"
    Width="480"
    SizeToContent="Height"
    MinHeight="300"
    MaxHeight="500"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                <GradientStop Offset="0.00" Color="{DynamicResource WindowBackgroundColorPrimary}" />
                <GradientStop Offset="0.80" Color="{DynamicResource WindowBackgroundColorSecondary}" />
                <GradientStop Offset="1.10" Color="{DynamicResource WindowBackgroundColorThird}" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Import / Export Configuration"
            Grid.Row="0"
            Padding="8"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="24,16" VerticalAlignment="Center">
            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                BorderThickness="1"
                Margin="0,0,0,12">
                <StackPanel>
                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="32" Margin="0,0,0,8" />
                    <TextBlock
                        Text="Export Configuration"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,0,0,4" />
                    <TextBlock
                        Text="Save all settings (FastFlags, ClientSettings, Bootstrapper, State, Themes) to a .hercules file."
                        TextWrapping="Wrap"
                        FontSize="13"
                        Opacity="0.7"
                        Margin="0,0,0,12" />
                    <ui:Button
                        x:Name="ExportButton"
                        Content="Export to .hercules"
                        Icon="Save24"
                        Appearance="Primary"
                        HorizontalAlignment="Stretch"
                        Click="ExportButton_Click" />
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                BorderThickness="1">
                <StackPanel>
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="32" Margin="0,0,0,8" />
                    <TextBlock
                        Text="Import Configuration"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,0,0,4" />
                    <TextBlock
                        Text="Load all settings from a .hercules file and apply them."
                        TextWrapping="Wrap"
                        FontSize="13"
                        Opacity="0.7"
                        Margin="0,0,0,12" />
                    <ui:Button
                        x:Name="ImportButton"
                        Content="Import from .hercules"
                        Icon="FolderOpen24"
                        Appearance="Primary"
                        HorizontalAlignment="Stretch"
                        Click="ImportButton_Click" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="13" Margin="0,12,0,0" TextAlignment="Center" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="14,10"
            Background="{DynamicResource PrimaryBackgroundColor}"
            BorderThickness="0,1,0,0">
            <StackPanel
                HorizontalAlignment="Right"
                FlowDirection="LeftToRight"
                Orientation="Horizontal">
                <Button
                    MinWidth="100"
                    Click="CloseButton_Click"
                    Content="{x:Static resources:Strings.Common_Close}" />
            </StackPanel>
        </Border>
    </Grid>
</base:WpfUiWindow>

<ui:UiPage
    x:Class="Hercules.UI.Elements.Settings.Pages.MobilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Hercules.UI.Elements.Controls"
    Title="Mobile Support">

    <StackPanel>
        <StackPanel Margin="0,0,0,16">
            <TextBlock
                FontSize="14"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Use Chrome Remote Desktop for Mobile/Tablet Support. Hercules never downloads or executes third-party installers automatically." />
        </StackPanel>

        <ui:Card x:Name="InstallerCard" Margin="0,0,0,16" Padding="24" Width="400">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Margin="0,8,0,12" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Checking installation..." TextAlignment="Center" TextWrapping="Wrap"/>
                <ui:Button Content="Open official setup" Appearance="Primary" Click="OpenRemoteDesktopSetup_Click" />
            </StackPanel>
        </ui:Card>

        <ui:Card x:Name="CompletionCard" Margin="0,0,0,16" Padding="32" Width="700" Height="250" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontSize="62" Text="📱" TextAlignment="Center"/>
                <TextBlock FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                           Text="Mobile Support" 
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Width="500"/>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                           Text="Chrome Remote Desktop is installed. Use the official website to configure or access your computer."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Width="500"/>
            </StackPanel>
        </ui:Card>
    </StackPanel>
</ui:UiPage>
